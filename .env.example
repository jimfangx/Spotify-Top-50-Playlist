MONGODB_URI=mongodb+srv://user:password@cluster.example.mongodb.net/
MONGODB_DB_NAME=spotifytop50DB
MONGODB_AUTH_COLLECTION=auth
MONGODB_TRACKS_COLLECTION=top_tracks

SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=http://localhost:8080/callback
SPOTIFY_PLAYLIST_ID=your_playlist_id
SPOTIFY_TOP_TRACKS_TIME_RANGE=short_term
SPOTIFY_TOP_TRACKS_LIMIT=50

UPDATE_SECRET=generate_a_long_random_value
PORT=8080
